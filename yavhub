                d.boxOutline.Visible = true d.boxOutline.Size = Vector2.new(w, h) d.boxOutline.Position = Vector2.new(pos.X - w/2, pos.Y - h/2)
                d.box.Visible = true d.box.Size = d.boxOutline.Size d.box.Position = d.boxOutline.Position d.box.Color = ESPColor
                if TracersEnabled then d.tracer.Visible = true d.tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y) d.tracer.To = Vector2.new(pos.X, pos.Y + h/2) d.tracer.Color = ESPColor else d.tracer.Visible = false end
                if ShowHealthBars then
