                    d.healthBarOutline.Visible = true d.healthBarOutline.Size = Vector2.new(4, h) d.healthBarOutline.Position = Vector2.new(pos.X - w/2 - 6, pos.Y - h/2)
                    d.healthBar.Visible = true d.healthBar.Size = Vector2.new(2, h * hpPercent) d.healthBar.Position = Vector2.new(pos.X - w/2 - 5, pos.Y + h/2 - (h * hpPercent))
                    d.healthBar.Color = Color3.fromRGB(255 - (255 * hpPercent), 255 * hpPercent, 0)
                else d.healthBarOutline.Visible = false d.healthBar.Visible = false end
            else if d then for _,v in pairs(d) do v.Visible = false end end end
        end
